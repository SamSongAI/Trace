<?xml version="1.0" encoding="utf-8"?>
<!--
  Trace Windows client MSI — WiX v4 declaration.

  Build (local dev / CI):
    wix build -arch x64 ^
      -d Version=0.1.0 ^
      -d BinDir=..\..\target\x86_64-pc-windows-msvc\release ^
      -d AssetsDir=..\assets ^
      -ext WixToolset.UI.wixext ^
      -o Trace-0.1.0-x64.msi Product.wxs

  ===========================================================================
  UpgradeCode is FIXED for the lifetime of this product. Windows Installer
  uses it as the identity every ProductCode maps back to; changing it would
  make every future release look like a separate product and break the
  MajorUpgrade path (double-install instead of in-place upgrade).

  Generated 2026-04-22 — DO NOT EDIT the GUID below.
  ===========================================================================
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
      Name="Trace"
      Manufacturer="Sam Song"
      Version="$(Version)"
      UpgradeCode="4F0FC3A3-C718-4DD4-BB01-0351E9960E8C"
      Compressed="yes"
      Scope="perMachine"
      InstallerVersion="500">

    <SummaryInformation Description="Trace — macOS 风格的系统级快速捕获工具（Windows 版）" />

    <!--
      MajorUpgrade: schedule afterInstallInitialize so the old version is
      uninstalled before the new one lays files down. %APPDATA%\Trace is
      user-owned data, so the installer never touches it — notes, settings,
      and daily files survive every upgrade automatically.
    -->
    <MajorUpgrade
        Schedule="afterInstallInitialize"
        DowngradeErrorMessage="已安装更新的 Trace 版本，无法降级。" />

    <!--
      图标 + ARP (Add/Remove Programs) 元数据。ARPPRODUCTICON 指向一个
      先前声明的 <Icon Id="...ico">（WiX v4 要求 Id 以 .ico 结尾），其余
      ARP* 属性填充控制面板「程序与功能」条目的 publisher / help link /
      contact / 禁用修复与修改（我们没有独立 repair CA，就关掉）。
    -->
    <Icon Id="TraceIcon.ico" SourceFile="$(AssetsDir)\trace.ico" />
    <Property Id="ARPPRODUCTICON" Value="TraceIcon.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/SamSong1997/Trace" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/SamSong1997/Trace" />
    <Property Id="ARPCONTACT" Value="samsong199705@gmail.com" />
    <Property Id="ARPNOMODIFY" Value="1" />
    <Property Id="ARPNOREPAIR" Value="1" />

    <MediaTemplate EmbedCab="yes" />

    <!-- 目录结构: C:\Program Files\Trace\ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Trace" />
    </StandardDirectory>

    <!--
      开始菜单子目录: Start Menu\Programs\Trace\Trace.lnk。桌面快捷方式
      落在 DesktopFolder 根下，不再嵌套子目录。StandardDirectory 引用
      的是 Windows Installer 预定义的标准路径，安装时自动展开。
    -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Trace" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />

    <!--
      主 exe 组件。Guid="*" tells WiX to hash the file path so the GUID is
      stable across rebuilds as long as the component's identity (file
      location + keypath) does not change.
    -->
    <ComponentGroup Id="TraceAppComponents" Directory="INSTALLFOLDER">
      <Component Id="TraceAppExe" Guid="*">
        <File Id="TraceAppExeFile"
              Source="$(BinDir)\trace-app.exe"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!--
      开始菜单快捷方式。MSI 要求每个 Component 有且仅有一个 KeyPath。
      Shortcut 本身不是合法的 KeyPath，所以补一条 Registry 条目做 KeyPath。

      Root="HKMU" 是 WiX 的魔法：perMachine 安装时解析成 HKLM，perUser
      安装时解析成 HKCU。用 HKMU 而不是 HKCU 避免经典陷阱——perMachine
      + HKCU KeyPath 的组合会让每个新登录的 Windows 用户首次运行 Trace
      时触发 self-repair（因为 HKCU 只写入了安装者那份 hive），在多用户
      机器上表现为反复弹 UAC 安装提示。HKMU 把 KeyPath 放到全机可见的
      HKLM 下，新用户运行时不会再触发修复。

      RemoveFolder 保证 uninstall 时顺手把父目录 Start Menu\Programs\
      Trace 移掉，否则会留下空目录。
    -->
    <ComponentGroup Id="StartMenuShortcuts" Directory="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="*">
        <Shortcut Id="StartMenuShortcutExe"
                  Name="Trace"
                  Description="Trace — 快速捕获"
                  Target="[INSTALLFOLDER]trace-app.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="TraceIcon.ico" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder"
                      Directory="ApplicationProgramsFolder"
                      On="uninstall" />
        <RegistryValue Root="HKMU"
                       Key="Software\Trace\Installer"
                       Name="StartMenuShortcutInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!--
      桌面快捷方式。拆成独立 Feature (DesktopShortcutFeature) + AllowAbsent
      以便用户在 "Custom Setup" 页面取消勾选。KeyPath 同样走 HKMU 而非
      HKCU，原因见 StartMenuShortcuts 的注释。桌面快捷方式落在 Desktop
      Folder 根下，不需要 RemoveFolder。
    -->
    <ComponentGroup Id="DesktopShortcutComponents" Directory="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="*">
        <Shortcut Id="DesktopShortcutExe"
                  Name="Trace"
                  Description="Trace — 快速捕获"
                  Target="[INSTALLFOLDER]trace-app.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="TraceIcon.ico" />
        <RegistryValue Root="HKMU"
                       Key="Software\Trace\Installer"
                       Name="DesktopShortcutInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- 主特性: 必装项（主 exe + 开始菜单快捷方式） -->
    <Feature Id="MainFeature" Title="Trace" Level="1"
             Description="Trace 主程序">
      <ComponentGroupRef Id="TraceAppComponents" />
      <ComponentGroupRef Id="StartMenuShortcuts" />
    </Feature>

    <!-- 桌面快捷方式: 可选 Feature，AllowAbsent=yes 允许用户反选 -->
    <Feature Id="DesktopShortcutFeature"
             Title="桌面快捷方式"
             Level="1"
             AllowAbsent="yes"
             Description="在桌面创建 Trace 图标">
      <ComponentGroupRef Id="DesktopShortcutComponents" />
    </Feature>

    <!--
      UI: WixUI_InstallDir shows Welcome -> EULA -> InstallDir -> Ready
      -> Progress -> Exit. The extension is referenced via xmlns:ui at
      the top and -ext WixToolset.UI.wixext on the command line.
    -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(AssetsDir)\LICENSE.rtf" />
  </Package>
</Wix>
